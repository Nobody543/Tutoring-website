<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TMUA Simulator — 2016 Paper 1</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500&family=DM+Mono:wght@300;400&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/KaTeX/0.16.9/katex.min.css">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --navy:#0b1220;--navy-mid:#111c30;--navy-light:#192540;
  --gold:#c8a96e;--gold-light:#dfc08a;--gold-dim:#8a6d40;
  --cream:#f5f0e8;--cream-dim:#b8b0a0;--white:#fff;
  --border:rgba(200,169,110,.2);--border-dim:rgba(200,169,110,.08);
  --green:#22c55e;--red:#ef4444;--amber:#f59e0b;
  --green-bg:rgba(34,197,94,.12);--red-bg:rgba(239,68,68,.12);--amber-bg:rgba(245,158,11,.1);
}
html{scroll-behavior:smooth}
body{background:var(--navy);color:var(--cream);font-family:'Outfit',sans-serif;font-weight:300;line-height:1.6;min-height:100vh;overflow-x:hidden}
.hidden{display:none!important}

/* ── START SCREEN ── */
#start-screen{min-height:100vh;display:flex;align-items:center;justify-content:center;padding:2rem;position:relative;overflow:hidden}
.start-grid-bg{position:absolute;inset:0;background-image:linear-gradient(rgba(200,169,110,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(200,169,110,.04) 1px,transparent 1px);background-size:60px 60px;pointer-events:none}
.start-inner{max-width:660px;width:100%;position:relative;z-index:1;text-align:center}
.start-eyebrow{font-family:'DM Mono',monospace;font-size:.72rem;letter-spacing:.18em;text-transform:uppercase;color:var(--gold);margin-bottom:1.5rem;display:flex;align-items:center;justify-content:center;gap:1rem}
.start-eyebrow::before,.start-eyebrow::after{content:'';display:block;width:30px;height:1px;background:var(--gold)}
.start-inner h1{font-family:'Cormorant Garamond',serif;font-size:clamp(2.5rem,6vw,4.5rem);font-weight:300;line-height:1.05;color:var(--white);margin-bottom:.4rem}
.start-inner h1 em{font-style:italic;color:var(--gold)}
.start-sub{font-family:'DM Mono',monospace;font-size:.72rem;letter-spacing:.14em;text-transform:uppercase;color:var(--gold-dim);margin-bottom:2rem}
.start-stats{display:flex;gap:1px;background:var(--border-dim);border:1px solid var(--border-dim);margin-bottom:2rem}
.start-stat{flex:1;background:var(--navy);padding:1.1rem 1rem;text-align:center}
.stat-val{font-family:'Cormorant Garamond',serif;font-size:2rem;font-weight:500;color:var(--gold);line-height:1}
.stat-lbl{font-family:'DM Mono',monospace;font-size:.6rem;letter-spacing:.12em;text-transform:uppercase;color:var(--gold-dim);margin-top:.3rem}
.start-rules{border:1px solid var(--border-dim);padding:1.8rem 2rem;text-align:left;margin-bottom:2rem;background:rgba(255,255,255,.02)}
.start-rules p{font-size:.9rem;color:var(--cream-dim);line-height:1.85;margin-bottom:.7rem}
.start-rules p:last-child{margin-bottom:0}
.start-rules strong{color:var(--cream);font-weight:500}
/* name field */
.name-wrap{margin-bottom:2rem;text-align:left}
.name-label{font-family:'DM Mono',monospace;font-size:.65rem;letter-spacing:.18em;text-transform:uppercase;color:var(--gold-dim);display:block;margin-bottom:.6rem}
#candidate-name{width:100%;background:rgba(255,255,255,.04);border:1.5px solid var(--border);color:var(--cream);font-family:'Outfit',sans-serif;font-size:.95rem;font-weight:400;padding:.75rem 1rem;outline:none;transition:border-color .2s}
#candidate-name::placeholder{color:var(--cream-dim);opacity:.5}
#candidate-name:focus{border-color:var(--gold)}
.name-error{font-family:'DM Mono',monospace;font-size:.65rem;letter-spacing:.08em;color:var(--red);margin-top:.5rem;display:none}
.btn-start{display:inline-block;background:var(--gold);color:var(--navy);padding:1rem 3rem;font-size:.85rem;font-weight:500;letter-spacing:.12em;text-transform:uppercase;border:none;cursor:pointer;transition:background .25s,transform .2s}
.btn-start:hover{background:var(--gold-light);transform:translateY(-1px)}

/* ── 10-MIN WARNING OVERLAY ── */
#warn-overlay{position:fixed;inset:0;z-index:500;display:flex;align-items:center;justify-content:center;background:rgba(11,18,32,.8);backdrop-filter:blur(8px)}
#warn-box{max-width:420px;width:90%;background:var(--navy-mid);border:1px solid rgba(245,158,11,.4);padding:2.5rem;text-align:center}
.warn-icon{font-size:2rem;margin-bottom:1rem;color:var(--amber)}
.warn-title{font-family:'Cormorant Garamond',serif;font-size:2rem;font-weight:300;color:var(--white);margin-bottom:.6rem}
.warn-sub{font-size:.9rem;color:var(--cream-dim);line-height:1.8;margin-bottom:1.5rem}
.warn-dismiss{background:var(--amber);color:var(--navy);border:none;padding:.7rem 2rem;font-family:'DM Mono',monospace;font-size:.72rem;letter-spacing:.1em;text-transform:uppercase;cursor:pointer;transition:opacity .2s}
.warn-dismiss:hover{opacity:.85}

/* ── EXAM HEADER ── */
#exam-header{position:fixed;top:0;left:0;right:0;z-index:100;height:60px;padding:0 1.5rem;display:flex;align-items:center;justify-content:space-between;background:rgba(11,18,32,.95);backdrop-filter:blur(12px);border-bottom:1px solid var(--border-dim)}
.header-left{display:flex;align-items:center;gap:1.2rem}
.header-paper{font-family:'DM Mono',monospace;font-size:.68rem;letter-spacing:.14em;text-transform:uppercase;color:var(--gold-dim)}
#header-name{font-family:'DM Mono',monospace;font-size:.68rem;letter-spacing:.08em;color:var(--cream-dim)}
.header-counter{font-family:'DM Mono',monospace;font-size:.75rem;letter-spacing:.1em;color:var(--cream-dim)}
#timer{font-family:'DM Mono',monospace;font-size:1.1rem;font-weight:400;letter-spacing:.05em;color:var(--cream);min-width:70px;text-align:right}
#timer.warn{color:var(--amber)}
#timer.danger{color:var(--red);animation:timerpulse 1s infinite}
@keyframes timerpulse{0%,100%{opacity:1}50%{opacity:.5}}

/* ── PROGRESS + DOTS ── */
#progress-bar{position:fixed;top:60px;left:0;right:0;height:3px;background:var(--border-dim);z-index:99}
#progress-fill{height:100%;background:var(--gold);transition:width .3s ease;width:5%}
#q-dots-bar{position:fixed;top:63px;left:0;right:0;z-index:98;display:flex;justify-content:center;flex-wrap:wrap;align-items:center;gap:3px;padding:7px 1rem;background:rgba(11,18,32,.9)}
.q-dot{width:22px;height:22px;border-radius:50%;border:1.5px solid var(--border);background:transparent;display:flex;align-items:center;justify-content:center;font-family:'DM Mono',monospace;font-size:.52rem;color:var(--cream-dim);cursor:pointer;transition:all .2s}
.q-dot:hover{border-color:var(--gold);color:var(--gold)}
.q-dot.answered{background:rgba(200,169,110,.14);border-color:var(--gold-dim);color:var(--gold)}
.q-dot.current{border-color:var(--gold);color:var(--gold);background:rgba(200,169,110,.22)}
.q-dot.flagged{border-color:var(--amber);background:rgba(245,158,11,.12)}

/* ── QUESTION CARD ── */
#exam-main{padding:126px 1.5rem 100px;max-width:900px;margin:0 auto}
#q-card{border:1px solid var(--border-dim);background:var(--navy-mid);padding:2rem 2.5rem;margin-bottom:1.5rem}
.q-badge{font-family:'DM Mono',monospace;font-size:.65rem;letter-spacing:.18em;text-transform:uppercase;color:var(--gold-dim);margin-bottom:1rem;display:flex;align-items:center;gap:.8rem}
.q-badge::before{content:'';display:block;width:18px;height:1px;background:var(--gold-dim)}
#q-text{font-size:.97rem;color:var(--cream);line-height:1.9}
#q-text p{margin-bottom:.8rem}
#q-text p:last-child{margin-bottom:0}
#options-grid{display:grid;grid-template-columns:1fr 1fr;gap:.7rem}
@media(max-width:600px){#options-grid{grid-template-columns:1fr}}
.opt-btn{display:flex;align-items:flex-start;gap:.9rem;padding:.85rem 1.1rem;border:1.5px solid var(--border-dim);background:rgba(255,255,255,.015);cursor:pointer;transition:all .2s;text-align:left;width:100%;color:var(--cream)}
.opt-btn:hover{border-color:var(--border);background:rgba(255,255,255,.04)}
.opt-btn.selected{border-color:var(--gold);background:rgba(200,169,110,.09)}
.opt-letter{font-family:'DM Mono',monospace;font-size:.7rem;letter-spacing:.1em;color:var(--gold-dim);min-width:18px;margin-top:.1rem;flex-shrink:0}
.opt-btn.selected .opt-letter{color:var(--gold)}
.opt-text{font-size:.88rem;line-height:1.6}

/* ── EXAM NAV BAR ── */
#exam-nav{position:fixed;bottom:0;left:0;right:0;height:64px;background:rgba(11,18,32,.96);backdrop-filter:blur(12px);border-top:1px solid var(--border-dim);display:flex;align-items:center;justify-content:space-between;gap:.8rem;padding:0 1.5rem;z-index:100}
.nav-btn{background:none;border:1px solid var(--border);color:var(--cream-dim);padding:.5rem 1.1rem;font-family:'DM Mono',monospace;font-size:.68rem;letter-spacing:.1em;text-transform:uppercase;cursor:pointer;transition:all .2s}
.nav-btn:hover:not(:disabled){border-color:var(--gold-dim);color:var(--cream)}
.nav-btn:disabled{opacity:.3;cursor:not-allowed}
.flag-btn{background:none;border:1px solid var(--border-dim);color:var(--cream-dim);padding:.5rem .95rem;font-family:'DM Mono',monospace;font-size:.66rem;letter-spacing:.08em;text-transform:uppercase;cursor:pointer;transition:all .2s}
.flag-btn.flagged{border-color:var(--amber);color:var(--amber)}
.submit-btn{background:var(--gold);color:var(--navy);border:none;padding:.5rem 1.4rem;font-family:'DM Mono',monospace;font-size:.7rem;letter-spacing:.1em;text-transform:uppercase;cursor:pointer;transition:background .25s}
.submit-btn:hover{background:var(--gold-light)}

/* ── RESULTS ── */
#results-screen{min-height:100vh;padding:4rem 1.5rem 3rem;overflow-y:auto}
.results-wrap{max-width:900px;margin:0 auto}
.results-eyebrow{font-family:'DM Mono',monospace;font-size:.68rem;letter-spacing:.18em;text-transform:uppercase;color:var(--gold);margin-bottom:1.5rem;display:flex;align-items:center;gap:.8rem}
.results-eyebrow::before{content:'';display:block;width:24px;height:1px;background:var(--gold)}
.results-wrap h2{font-family:'Cormorant Garamond',serif;font-size:clamp(2rem,5vw,3.5rem);font-weight:300;color:var(--white);margin-bottom:2.5rem}
.results-wrap h2 em{font-style:italic;color:var(--gold)}
.score-panel{display:grid;grid-template-columns:1fr 1fr 1fr;gap:1.2rem;margin-bottom:2.5rem}
@media(max-width:700px){.score-panel{grid-template-columns:1fr 1fr}}
@media(max-width:420px){.score-panel{grid-template-columns:1fr}}
.score-card{border:1px solid var(--border);padding:1.8rem 1.5rem;background:rgba(200,169,110,.02)}
.score-card.feat{border-color:var(--gold);background:rgba(200,169,110,.06)}
.sc-label{font-family:'DM Mono',monospace;font-size:.63rem;letter-spacing:.15em;text-transform:uppercase;color:var(--gold-dim);margin-bottom:.8rem}
.sc-val{font-family:'Cormorant Garamond',serif;font-size:3.2rem;font-weight:500;color:var(--white);line-height:1}
.sc-sub{font-size:.8rem;color:var(--cream-dim);margin-top:.4rem}
.perf-tag{display:inline-block;margin-top:.8rem;font-family:'DM Mono',monospace;font-size:.6rem;letter-spacing:.1em;text-transform:uppercase;padding:.25rem .7rem}
.perf-excellent{background:rgba(34,197,94,.15);color:#4ade80;border:1px solid rgba(34,197,94,.3)}
.perf-good{background:rgba(200,169,110,.12);color:var(--gold);border:1px solid var(--border)}
.perf-avg{background:rgba(245,158,11,.1);color:var(--amber);border:1px solid rgba(245,158,11,.3)}
.perf-below{background:rgba(239,68,68,.1);color:#f87171;border:1px solid rgba(239,68,68,.3)}
.section-label-sm{font-family:'DM Mono',monospace;font-size:.65rem;letter-spacing:.18em;text-transform:uppercase;color:var(--gold-dim);margin-bottom:1rem;display:flex;align-items:center;gap:.6rem}
.section-label-sm::before{content:'';display:block;width:18px;height:1px;background:var(--gold-dim)}
.rq-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(52px,1fr));gap:.45rem;margin-bottom:2rem}
.rq-btn{height:52px;border:1.5px solid var(--border-dim);background:rgba(255,255,255,.02);font-family:'DM Mono',monospace;font-size:.7rem;cursor:pointer;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2px;transition:all .2s;color:var(--cream-dim)}
.rq-btn:hover{border-color:var(--border)}
.rq-btn .rq-num{font-size:.68rem}
.rq-btn .rq-mark{font-size:.6rem}
.rq-btn.correct{border-color:var(--green);background:var(--green-bg);color:var(--green)}
.rq-btn.incorrect{border-color:var(--red);background:var(--red-bg);color:var(--red)}
.rq-btn.skipped{border-color:var(--amber);background:var(--amber-bg);color:var(--amber)}
.review-hint{font-family:'DM Mono',monospace;font-size:.67rem;letter-spacing:.1em;color:var(--gold-dim);text-align:center;margin-bottom:2rem;opacity:.7}
/* email report btn */
.email-row{display:flex;align-items:center;gap:1rem;margin-bottom:2.5rem;flex-wrap:wrap}
.email-report-btn{display:inline-flex;align-items:center;gap:.6rem;background:var(--gold);color:var(--navy);border:none;padding:.75rem 1.6rem;font-family:'DM Mono',monospace;font-size:.7rem;letter-spacing:.1em;text-transform:uppercase;cursor:pointer;text-decoration:none;transition:background .25s}
.email-report-btn:hover{background:var(--gold-light)}
.email-hint{font-size:.8rem;color:var(--cream-dim);font-style:italic}

/* ── REVIEW MODAL ── */
#review-modal{position:fixed;inset:0;z-index:200;display:flex;align-items:flex-start;justify-content:center;padding:1rem}
#review-backdrop{position:absolute;inset:0;background:rgba(11,18,32,.85)}
#review-panel{position:relative;z-index:1;background:var(--navy-mid);border:1px solid var(--border);width:100%;max-width:780px;max-height:90vh;overflow-y:auto;margin-top:2rem}
.rev-header{display:flex;align-items:center;justify-content:space-between;padding:1.1rem 1.5rem;border-bottom:1px solid var(--border-dim);position:sticky;top:0;background:var(--navy-mid);z-index:1}
.rev-header-left{display:flex;align-items:center;gap:1rem}
.rev-q-badge{font-family:'DM Mono',monospace;font-size:.65rem;letter-spacing:.14em;text-transform:uppercase;color:var(--gold)}
.rev-nav-btns{display:flex;gap:.4rem}
.rev-nav-btn{background:none;border:1px solid var(--border-dim);color:var(--cream-dim);padding:.3rem .7rem;font-family:'DM Mono',monospace;font-size:.63rem;letter-spacing:.08em;text-transform:uppercase;cursor:pointer;transition:all .15s}
.rev-nav-btn:hover:not(:disabled){border-color:var(--border);color:var(--cream)}
.rev-nav-btn:disabled{opacity:.3;cursor:not-allowed}
.close-btn{background:none;border:none;color:var(--cream-dim);font-size:1.2rem;cursor:pointer;padding:.3rem .5rem;line-height:1}
.close-btn:hover{color:var(--cream)}
.rev-body{padding:1.5rem}
.rev-q-text{font-size:.93rem;color:var(--cream);line-height:1.9;margin-bottom:1.5rem;padding-bottom:1.5rem;border-bottom:1px solid var(--border-dim)}
.rev-status{font-size:.83rem;margin-bottom:1rem;padding:.5rem .8rem;border-left:3px solid}
.rev-status.correct{color:#4ade80;border-color:var(--green);background:var(--green-bg)}
.rev-status.incorrect{color:#f87171;border-color:var(--red);background:var(--red-bg)}
.rev-status.skipped{color:var(--amber);border-color:var(--amber);background:var(--amber-bg)}
.rev-options{display:flex;flex-direction:column;gap:.45rem;margin-bottom:1.5rem}
.rev-opt{display:flex;align-items:flex-start;gap:.8rem;padding:.7rem 1rem;border:1.5px solid var(--border-dim);background:transparent}
.rev-opt.user-correct{border-color:var(--green);background:var(--green-bg)}
.rev-opt.user-wrong{border-color:var(--red);background:var(--red-bg)}
.rev-opt.correct-hi{border-color:var(--green);background:var(--green-bg)}
.rev-opt-letter{font-family:'DM Mono',monospace;font-size:.68rem;letter-spacing:.1em;min-width:18px;flex-shrink:0;margin-top:.1rem;color:var(--cream-dim)}
.rev-opt.user-correct .rev-opt-letter{color:var(--green)}
.rev-opt.user-wrong .rev-opt-letter{color:var(--red)}
.rev-opt.correct-hi .rev-opt-letter{color:var(--green)}
.rev-opt-text{font-size:.86rem;line-height:1.6;color:var(--cream-dim);flex:1}
.rev-opt.user-correct .rev-opt-text,.rev-opt.user-wrong .rev-opt-text,.rev-opt.correct-hi .rev-opt-text{color:var(--cream)}
.rev-tag{font-family:'DM Mono',monospace;font-size:.55rem;letter-spacing:.08em;text-transform:uppercase;padding:.15rem .45rem;margin-left:.4rem;flex-shrink:0;vertical-align:middle}
.tag-correct{background:rgba(34,197,94,.18);color:#4ade80}
.tag-wrong{background:rgba(239,68,68,.18);color:#f87171}
.rev-solution{padding:1.2rem 1.4rem;border:1px solid var(--border-dim);background:rgba(200,169,110,.025)}
.rev-sol-label{font-family:'DM Mono',monospace;font-size:.62rem;letter-spacing:.14em;text-transform:uppercase;color:var(--gold-dim);margin-bottom:.8rem;display:flex;align-items:center;gap:.5rem}
.rev-sol-label::before{content:'';display:block;width:14px;height:1px;background:var(--gold-dim)}
.rev-sol-text{font-size:.87rem;color:var(--cream-dim);line-height:1.9}
.rev-sol-text p{margin-bottom:.6rem}
.rev-sol-text p:last-child{margin-bottom:0}
.rev-sol-text strong{color:var(--cream);font-weight:500}
.rev-sol-text .note{font-size:.8rem;color:var(--amber);font-style:italic;margin-top:.5rem}

@media(max-width:480px){
  #exam-main{padding:126px .8rem 100px}
  #q-card{padding:1.2rem 1rem}
  #exam-nav{padding:0 .8rem;gap:.4rem}
  .nav-btn,.flag-btn,.submit-btn{padding:.42rem .7rem;font-size:.6rem}
}
.katex{font-size:1em}
.opt-text .katex,.rev-opt-text .katex{font-size:.94em}
</style>
</head>
<body>

<!-- ════════════ START SCREEN ════════════ -->
<div id="start-screen">
  <div class="start-grid-bg"></div>
  <div class="start-inner">
    <p class="start-eyebrow">TMUA Simulator</p>
    <h1>2016 <em>Paper 1</em></h1>
    <p class="start-sub">Practice paper · Cambridge Assessment</p>
    <div class="start-stats">
      <div class="start-stat"><div class="stat-val">20</div><div class="stat-lbl">Questions</div></div>
      <div class="start-stat"><div class="stat-val">75</div><div class="stat-lbl">Minutes</div></div>
      <div class="start-stat"><div class="stat-val">1–9</div><div class="stat-lbl">Score scale</div></div>
    </div>
    <div class="start-rules">
      <p><strong>This is a timed simulation of TMUA Paper 1 (2016).</strong> Each question has exactly one correct answer. No penalties apply for incorrect responses — attempt every question.</p>
      <p>The 75-minute clock begins when you click Begin. The paper will be submitted automatically when time expires. No calculators are permitted.</p>
      <p>After submitting, you will receive a grade based on the official TMUA conversion table, and can review every question with full worked solutions. A score report will be sent by email.</p>
    </div>
    <div class="name-wrap">
      <label class="name-label" for="candidate-name">Your full name</label>
      <input type="text" id="candidate-name" placeholder="e.g. Jane Smith" maxlength="60" autocomplete="off">
      <div class="name-error" id="name-error">Please enter your name before starting.</div>
    </div>
    <button class="btn-start" id="begin-btn">Begin Paper</button>
  </div>
</div>

<!-- ════════════ 10-MIN WARNING ════════════ -->
<div id="warn-overlay" class="hidden">
  <div id="warn-box">
    <div class="warn-icon">⏳</div>
    <div class="warn-title">10 minutes remaining</div>
    <p class="warn-sub">You have <strong>10 minutes</strong> left on this paper. Ensure all questions you wish to answer have been selected — the paper will submit automatically when the timer reaches zero.</p>
    <button class="warn-dismiss" id="warn-dismiss">Continue →</button>
  </div>
</div>

<!-- ════════════ EXAM SCREEN ════════════ -->
<div id="exam-screen" class="hidden">
  <header id="exam-header">
    <div class="header-left">
      <span class="header-paper">TMUA 2016 · Paper 1</span>
      <span id="header-name"></span>
    </div>
    <span class="header-counter" id="q-counter">Question 1 of 20</span>
    <span id="timer">1:15:00</span>
  </header>
  <div id="progress-bar"><div id="progress-fill"></div></div>
  <div id="q-dots-bar"></div>
  <main id="exam-main">
    <div id="q-card">
      <div class="q-badge" id="q-badge">Question 01</div>
      <div id="q-text"></div>
    </div>
    <div id="options-grid"></div>
  </main>
  <nav id="exam-nav">
    <button class="nav-btn" id="prev-btn">← Prev</button>
    <button class="flag-btn" id="flag-btn">⚑ Flag</button>
    <button class="nav-btn" id="next-btn">Next →</button>
    <button class="submit-btn" id="submit-btn">Submit Paper</button>
  </nav>
</div>

<!-- ════════════ RESULTS SCREEN ════════════ -->
<div id="results-screen" class="hidden">
  <div class="results-wrap">
    <p class="results-eyebrow">Paper Completed</p>
    <h2 id="results-heading">Your <em>Results</em></h2>
    <div class="score-panel">
      <div class="score-card feat">
        <div class="sc-label">Raw Score</div>
