<script>
// ═══════════ GRADE CONVERSION (official 2016 Paper 1) ═══════════
const GRADE_TABLE = {
  0:1.0,1:1.0,2:1.0,3:1.0,4:1.8,5:2.7,6:3.4,7:4.2,8:4.8,
  9:5.5,10:6.1,11:6.7,12:7.3,13:7.9,14:8.6,15:9.0,
  16:9.0,17:9.0,18:9.0,19:9.0,20:9.0
};

// ═══════════ QUESTIONS ═══════════
const QUESTIONS = [
{id:1,
text:`<p>The expression $(ax + b)^3$ expands to $8x^3 - px^2 + 18x - 3\\sqrt{3}$, where $a$, $b$ and $p$ are real numbers. What is the value of $p$?</p>`,
opts:{A:'$-12\\sqrt{3}$',B:'$-6\\sqrt{3}$',C:'$-4\\sqrt{3}$',D:'$-\\sqrt{3}$',E:'$\\sqrt{3}$',F:'$4\\sqrt{3}$',G:'$6\\sqrt{3}$',H:'$12\\sqrt{3}$'},
ans:'H',
sol:`<p>Expand $(ax+b)^3 = a^3x^3 + 3a^2bx^2 + 3ab^2x + b^3$ and compare with $8x^3-px^2+18x-3\\sqrt{3}$.</p>
<p>From the constant term: $b^3 = -3\\sqrt{3} = -(\\sqrt{3})^3$, so $b = -\\sqrt{3}$.</p>
<p>From the $x$ coefficient: $3ab^2 = 18 \\Rightarrow 3a(3)=18 \\Rightarrow a=2$.</p>
<p>From the $x^2$ coefficient: $3a^2b = -p \\Rightarrow 3(4)(-\\sqrt{3}) = -p \\Rightarrow p = 12\\sqrt{3}$.</p>
<p><strong>Answer: H</strong></p>`},

{id:2,
text:`<p>The polynomial $3x^3 + 13x^2 + 8x + a$, where $a$ is an integer, has $(x + 2)$ as a factor. Which of the following is the fully factorised form?</p>`,
opts:{A:'$(x+2)(x-1)(3x-2)$',B:'$(x+2)(x+1)(3x-2)$',C:'$(x+2)(x+1)(3x+2)$',D:'$(x+2)(x-3)(3x+2)$',E:'$(x+2)(x+3)(3x-2)$',F:'$(x+2)(x+3)(3x+2)$'},
ans:'E',
sol:`<p>By the factor theorem $f(-2)=0$: $-24+52-16+a=0 \\Rightarrow a=-12$.</p>
<p>Divide $3x^3+13x^2+8x-12$ by $(x+2)$: quotient is $3x^2+7x-6$.</p>
<p>Factorise: $(3x-2)(x+3)$. Full form: $(x+2)(x+3)(3x-2)$.</p>
<p><strong>Answer: E</strong></p>`},

{id:3,
text:`<p>The curve $y = \\dfrac{2}{x^2}$ has a normal drawn at the point where $x = 1$. This normal cuts the $x$-axis at $P$ and the $y$-axis at $Q$. What is the length $PQ$?</p>`,
opts:{A:'$\\dfrac{3\\sqrt{5}}{2}$',B:'$\\dfrac{3\\sqrt{17}}{4}$',C:'$\\dfrac{7\\sqrt{17}}{4}$',D:'$\\dfrac{35}{4}$',E:'$\\dfrac{35\\sqrt{5}}{2}$',F:'$\\dfrac{3\\sqrt{17}}{2}$'},
ans:'C',
sol:`<p>At $x=1$: $y=2$. Gradient of curve $= -4$, so normal gradient $= \\tfrac{1}{4}$.</p>
<p>Normal: $y-2=\\tfrac{1}{4}(x-1)$. At $y=0$: $x=-7$, so $P=(-7,0)$.</p>
<p>At $x=0$: $y=\\tfrac{7}{4}$, so $Q=(0,\\tfrac{7}{4})$.</p>
<p>$PQ = \\sqrt{49 + \\tfrac{49}{16}} = \\tfrac{7}{4}\\sqrt{17} = \\dfrac{7\\sqrt{17}}{4}$.</p>
<p><strong>Answer: C</strong></p>`},

{id:4,
text:`<p>A sequence is defined by $a_n = (-1)^n - (-1)^{n-1} + (-1)^{n+2}$ for $n \\geq 1$. Find $\\displaystyle\\sum_{n=1}^{39} a_n$.</p>`,
opts:{A:'$-39$',B:'$-3$',C:'$-1$',D:'$0$',E:'$1$',F:'$3$',G:'$39$'},
ans:'B',
sol:`<p>Compute: $a_1 = -1-1-1=-3$; $a_2=1+1+1=3$; pattern $-3,3,-3,3,\\ldots$</p>
<p>Consecutive pairs sum to zero. $\\sum_{n=1}^{38}=0$ (19 pairs). The 39th term is $a_{39}=-3$.</p>
<p><strong>Answer: B</strong></p>`},

{id:5,
text:`<p>What is the total area enclosed between the curve $y = x^2 - 1$, the $x$-axis and the lines $x = -2$ and $x = 2$?</p>`,
opts:{A:'$\\dfrac{4}{3}$',B:'$\\dfrac{8}{3}$',C:'$4$',D:'$\\dfrac{16}{3}$',E:'$12$',F:'$16$'},
ans:'C',
sol:`<p>Curve crosses $x$-axis at $x=\\pm1$. Three regions, each contributing $\\tfrac{4}{3}$ (take absolute values).</p>
<p>Total $= 3 \\times \\tfrac{4}{3} = 4$.</p>
<p><strong>Answer: C</strong></p>`},

{id:6,
text:`<p>Three paints P, Q and R are mixed in ratio 12 : 5 : 3 by volume. P contains 30% red and Q contains 20% red. The mixture contains 25% red. What percentage of R is red?</p>`,
opts:{A:'$25\\%$',B:'$23\\%$',C:'$13\\tfrac{1}{3}\\%$',D:'$19\\tfrac{1}{2}\\%$',E:'$9\\tfrac{3}{4}\\%$',F:'None of the above'},
ans:'C',
sol:`<p>$12(0.3)+5(0.2)+3x = 20(0.25) \\Rightarrow 3.6+1+3x=5 \\Rightarrow x=\\tfrac{2}{15}=13\\tfrac{1}{3}\\%$.</p>
<p><strong>Answer: C</strong></p>`},

{id:7,
text:`<p>A sports club has 300 members: 60% are women. $\\frac{2}{5}$ of male members play cricket. Of all cricket-playing members, $\\frac{2}{3}$ are women. A member is chosen at random. What is the probability that this member is a woman who plays tennis?</p>`,
opts:{A:'$\\dfrac{1}{5}$',B:'$\\dfrac{7}{25}$',C:'$\\dfrac{1}{3}$',D:'$\\dfrac{11}{25}$',E:'$\\dfrac{3}{5}$'},
ans:'B',
sol:`<p>Men=120, Women=180. Men cricket $=48$. Since men are $\\tfrac{1}{3}$ of cricketers: total cricketers$=144$, women cricketers$=96$.</p>
<p>Women tennis $=180-96=84$. $P=\\tfrac{84}{300}=\\tfrac{7}{25}$.</p>
<p><strong>Answer: B</strong></p>`},

{id:8,
text:`<p>Find the maximum value of $x$ in $0°\\leq x\\leq 360°$ satisfying $\\cos^2(2x)+\\sqrt{3}\\sin(2x)-\\tfrac{7}{4}=0$.</p>`,
opts:{A:'$30°$',B:'$60°$',C:'$120°$',D:'$150°$',E:'$210°$',F:'$240°$',G:'$300°$',H:'$330°$'},
ans:'F',
sol:`<p>Use $\\cos^2\\theta=1-\\sin^2\\theta$: equation becomes $\\sin^2(2x)-\\sqrt{3}\\sin(2x)+\\tfrac{3}{4}=0$, i.e. $(\\sin(2x)-\\tfrac{\\sqrt{3}}{2})^2=0$.</p>
<p>So $\\sin(2x)=\\tfrac{\\sqrt{3}}{2}$, giving $2x=60°,120°,420°,480°$, so $x=30°,60°,210°,240°$.</p>
<p>Maximum: <strong>$x=240°$</strong>. Answer: F</p>`},

{id:9,
text:`<p>A circle has diameter endpoints $(3,3)$ and $(7,5)$. It undergoes: translation $-3$ in $x$; reflection in $x$-axis; enlargement scale factor 4 about its own centre. What is the equation of the resulting circle?</p>`,
opts:{A:'$(x-2)^2+(y-4)^2=320$',B:'$(x-2)^2+(y+4)^2=320$',C:'$(x-2)^2+(y-4)^2=80$',D:'$(x-2)^2+(y+4)^2=80$',E:'$(x-2)^2+(y-4)^2=20$',F:'$(x-2)^2+(y+4)^2=20$'},
ans:'D',
sol:`<p>Centre $(5,4)$, radius $\\sqrt{5}$. After translation: $(2,4)$. After reflection: $(2,-4)$. After enlargement: radius $=4\\sqrt{5}$, centre unchanged.</p>
<p>$(x-2)^2+(y+4)^2=80$. <strong>Answer: D</strong></p>`},

{id:10,
text:`<p>How many solutions does $x\\tan x = 1$ have in $-2\\pi \\leq x \\leq 2\\pi$?</p>`,
opts:{A:'$0$',B:'$1$',C:'$2$',D:'$3$',E:'$4$',F:'$5$',G:'$6$'},
ans:'E',
sol:`<p>Rewrite as $\\tan x = 1/x$. Sketch $y=\\tan x$ and $y=1/x$ for $-2\\pi \\leq x \\leq 2\\pi$ (excluding $x=0$). Careful counting of intersections across all four relevant branches gives <strong>4 solutions</strong>.</p>
<p><strong>Answer: E</strong></p>`},

{id:11,
text:`<p>The equation $4^{2x} + 12 = 2^{2x+3}$ has solutions $p > q$. What is $p - q$?</p>`,
opts:{A:'$\\dfrac{3}{4}$',B:'$1$',C:'$4$',D:'$\\dfrac{\\log 3}{2\\log 2}-\\dfrac{1}{2}$',E:'$\\dfrac{\\log 3}{\\log 4}$'},
ans:'E',
sol:`<p>Let $y=2^{2x}$. Then $y^2-8y+12=0 \\Rightarrow y=2$ or $y=6$.</p>
<p>$2^{2q}=2 \\Rightarrow q=\\tfrac{1}{2}$; $2^{2p}=6 \\Rightarrow p=\\tfrac{\\log 6}{2\\log 2}$.</p>
<p>$p-q = \\tfrac{\\log 6-\\log 2}{2\\log 2} = \\dfrac{\\log 3}{\\log 4}$. <strong>Answer: E</strong></p>`},

{id:12,
text:`<p>A cylinder is inscribed in a sphere of radius 5 cm such that its volume is maximised. What is this maximum volume?</p>`,
opts:{A:'$50\\sqrt{2}\\,\\pi$ cm³',B:'$\\dfrac{500\\pi}{3}$ cm³',C:'$\\dfrac{1000\\pi}{3}$ cm³',D:'$\\dfrac{250\\sqrt{3}}{3}\\pi$ cm³',E:'$\\dfrac{500\\sqrt{3}}{9}\\pi$ cm³',F:'$\\dfrac{1000\\sqrt{3}}{9}\\pi$ cm³'},
ans:'E',
sol:`<p>Half-height $h$, radius $r$ with $r^2+h^2=25$. $V=2\\pi r^2 h=2\\pi(25-h^2)h$.</p>
<p>$dV/dh=2\\pi(25-3h^2)=0 \\Rightarrow h=5/\\sqrt{3}$, $r^2=50/3$.</p>
<p>$V=\\tfrac{500\\pi}{3\\sqrt{3}}=\\dfrac{500\\sqrt{3}\\,\\pi}{9}$ cm³. <strong>Answer: E</strong></p>`},

{id:13,
text:`<p>How many real roots does $3x^5 - 10x^3 - 120x + 30 = 0$ have?</p>`,
opts:{A:'$1$',B:'$2$',C:'$3$',D:'$4$',E:'$5$'},
ans:'C',
sol:`<p>$f'(x)=15x^4-30x^2-120=15(x^2-4)(x^2+2)=0$ at $x=\\pm2$.</p>
<p>$f(-2)=254>0$, $f(2)=-194<0$. One root each in $(-\\infty,-2)$, $(-2,2)$, $(2,\\infty)$.</p>
<p><strong>Answer: C — 3 real roots</strong></p>`},

{id:14,
text:`<p>Two geometric sequences $T$ and $U$ both start with first term 4. The sequence $S_n=T_n+U_n$ has first three terms $8, 3, \\frac{5}{4}$. What is $\\sum_{n=1}^{\\infty}S_n$?</p>`,
opts:{A:'$\\dfrac{32}{5}$',B:'$\\dfrac{20}{3}$',C:'$\\dfrac{64}{5}$',D:'$\\dfrac{40}{3}$',E:'$16$',F:'$32$'},
ans:'D',
sol:`<p>$R+r=\\tfrac{3}{4}$, $R^2+r^2=\\tfrac{5}{16}$, giving $Rr=\\tfrac{1}{8}$. Roots of $8t^2-6t+1=0$: $t=\\tfrac{1}{4},\\tfrac{1}{2}$.</p>
<p>$\\sum T=\\tfrac{4}{3/4}=\\tfrac{16}{3}$; $\\sum U=\\tfrac{4}{1/2}=8$. Total $=\\tfrac{16}{3}+8=\\dfrac{40}{3}$. <strong>Answer: D</strong></p>`},

{id:15,
text:`<p>Given $y=(2x+a)(x-2a)^2$, find the least possible gradient of the curve at $x=1$ as $a$ varies over all reals.</p>`,
opts:{A:'$-\\dfrac{49}{4}$',B:'$-8$',C:'$-\\dfrac{25}{4}$',D:'$\\dfrac{7}{4}$',E:'$\\dfrac{47}{16}$'},
ans:'C',
sol:`<p>Expand: $\\tfrac{dy}{dx}=6x^2-14ax+4a^2$. At $x=1$: $g(a)=4a^2-14a+6$.</p>
<p>Complete square: $4(a-\\tfrac{7}{4})^2-\\tfrac{25}{4}$. Minimum $=-\\dfrac{25}{4}$. <strong>Answer: C</strong></p>`},

{id:16,
text:`<p>Solve simultaneously:<br>$\\log_{10}2+\\log_{10}(y-1)=2\\log_{10}x$<br>$\\log_{10}(y+3-3x)=0$</p><p>Find the possible values of $y$.</p>`,
opts:{A:'$\\dfrac{5}{2}\\pm\\dfrac{3\\sqrt{5}}{2}$',B:'$3\\pm\\sqrt{3}$',C:'$7\\pm 3\\sqrt{3}$',D:'$y=3$ or $y=9$',E:'$y=1$ or $y=13$'},
ans:'C',
sol:`<p>Eq 1: $2(y-1)=x^2$. Eq 2: $y+3-3x=1 \\Rightarrow y=3x-2$, so $x=\\tfrac{y+2}{3}$.</p>
<p>$(y+2)^2/9=2y-2 \\Rightarrow y^2-14y+22=0 \\Rightarrow y=7\\pm3\\sqrt{3}$. <strong>Answer: C</strong></p>`},

{id:17,
text:`<p>For $0<x<\\pi$, find the values of $x$ for which $y=(1+2\\cos x)\\cos 2x$ is negative.</p>`,
opts:{A:'$0<x<\\tfrac{\\pi}{4}$ and $\\tfrac{2\\pi}{3}<x<\\tfrac{3\\pi}{4}$',B:'$0<x<\\tfrac{\\pi}{4}$ and $\\tfrac{3\\pi}{4}<x<\\pi$',C:'$0<x<\\tfrac{2\\pi}{3}$ and $\\tfrac{3\\pi}{4}<x<\\pi$',D:'$\\tfrac{\\pi}{4}<x<\\tfrac{2\\pi}{3}$ and $\\tfrac{3\\pi}{4}<x<\\pi$',E:'$\\tfrac{\\pi}{4}<x<\\tfrac{2\\pi}{3}$',F:'$\\tfrac{\\pi}{4}<x<\\tfrac{3\\pi}{4}$'},
ans:'D',
sol:`<p>Zeros: $1+2\\cos x=0$ at $x=\\tfrac{2\\pi}{3}$; $\\cos 2x=0$ at $x=\\tfrac{\\pi}{4},\\tfrac{3\\pi}{4}$.</p>
<p>Sign analysis: $y<0$ when exactly one factor is negative. This gives $\\tfrac{\\pi}{4}<x<\\tfrac{2\\pi}{3}$ and $\\tfrac{3\\pi}{4}<x<\\pi$. <strong>Answer: D</strong></p>`},

{id:18,
text:`<p>For $x\\neq 0$, find the values of $x$ for which $f(x)=\\dfrac{1-x}{x^{2/3}}$ is increasing.</p>`,
opts:{A:'$x\\leq -2$, $x>0$',B:'$-2\\leq x<0$',C:'$x\\leq 1$, $x\\neq 0$',D:'$x\\geq 1$',E:'$-2\\leq x\\leq 1$, $x\\neq 0$',F:'$x\\leq -2$, $x\\geq 1$'},
ans:'A',
sol:`<p>$f(x)=x^{-2/3}-x^{1/3}$, so $f'(x)=-\\tfrac{2}{3}x^{-5/3}-\\tfrac{1}{3}x^{-2/3}=-\\tfrac{x^{-5/3}}{3}(2+x)$.</p>
<p>Zero at $x=-2$. Sign of $f'$: when $x>0$, $x^{-5/3}>0$ and $(2+x)>0$, so $f'<0$. When $x<-2$, $x^{-5/3}<0$ and $(2+x)<0$, so $f'>0$. When $-2<x<0$, $x^{-5/3}<0$ and $(2+x)>0$, so $f'<0$.</p>
<p>Therefore $f$ is increasing for $x\\leq -2$ and $x>0$. <strong>Answer: A</strong></p>`},

{id:19,
text:`<p>The coefficient of $x^3$ in $(1+2x+3x^2)^6$ equals twice the coefficient of $x^4$ in $(1-ax^2)^5$. Find all possible values of $a$.</p>`,
opts:{A:'$\\pm 2\\sqrt{2}$',B:'$\\pm\\sqrt{17}$',C:'$\\pm\\sqrt{34}$',D:'$\\pm 2\\sqrt{17}$',E:'No real values'},
ans:'B',
sol:`<p><strong>Coeff of $x^3$ in $(1+2x+3x^2)^6$:</strong> Using $(1+u)^6$ where $u=2x+3x^2$: contributions are $\\binom{6}{1}(3x^2)(2x)+\\binom{6}{3}(2x)^3 = 6\\cdot6+20\\cdot8=36+160=340$. Wait — recount: $\\binom{6}{2}(2x)^2(3x^2)=15\\cdot4\\cdot3=180$ and $\\binom{6}{3}(2x)^3=20\\cdot8=160$, total $=340$.</p>
<p><strong>Coeff of $x^4$ in $(1-ax^2)^5$:</strong> $\\binom{5}{2}a^2=10a^2$.</p>
<p>$340=20a^2 \\Rightarrow a^2=17 \\Rightarrow a=\\pm\\sqrt{17}$. <strong>Answer: B</strong></p>`},

{id:20,
text:`<p>A pyramid $OPQRS$ has square base $PQRS$ and apex $O$. All edges are 20 m. Find the length of the shortest path along the surface from vertex $P$ to the midpoint of edge $OR$.</p>`,
opts:{A:'$10\\sqrt{5-2\\sqrt{3}}$ m',B:'$10\\sqrt{3}$ m',C:'$10\\sqrt{5}$ m',D:'$10\\sqrt{7}$ m',E:'$10\\sqrt{5+2\\sqrt{3}}$ m'},
ans:'D',
sol:`<p>Let $T$ be the midpoint of $OR$. Unfold the two candidate routes:</p>
<p><strong>Route via faces $OPS$ then $ORS$:</strong> After unfolding, $P$ is $10\\sqrt{3}$ from $OS$ on one side, $T$ is $5\\sqrt{3}$ from $OS$ on the other and 5 m above the base-edge. Straight-line distance $PT=\\sqrt{(15\\sqrt{3})^2+5^2}=\\sqrt{700}=10\\sqrt{7}$ m.</p>
<p><strong>Route via base face then $ORS$</strong> gives a longer path.</p>
<p><strong>Answer: D — $10\\sqrt{7}$ m</strong></p>`}
];

// ═══════════ STATE ═══════════
const S = {
  name:'', current:0, answers:{}, flagged:new Set(),
  timeLeft:75*60, timerInterval:null, started:false, submitted:false,
  warnShown:false, reviewQ:0
};

// ═══════════ MATH RENDERING ═══════════
function renderMath(el){
  if(typeof renderMathInElement==='function'){
    renderMathInElement(el,{
      delimiters:[{left:'$$',right:'$$',display:true},{left:'$',right:'$',display:false}],
      throwOnError:false
    });
  }
}

// ═══════════ TIMER ═══════════
function fmtTime(s){
  const m=Math.floor(s/60), sec=s%60;
  return `${String(m).padStart(2,'0')}:${String(sec).padStart(2,'0')}`;
}

function startTimer(){
  const timerEl=document.getElementById('timer');
  S.timerInterval=setInterval(()=>{
    S.timeLeft--;
    timerEl.textContent=fmtTime(S.timeLeft);
    if(S.timeLeft<=300) timerEl.className='danger';
    else if(S.timeLeft<=600) timerEl.className='warn';
    else timerEl.className='';
    if(S.timeLeft===600 && !S.warnShown){
      S.warnShown=true;
      document.getElementById('warn-overlay').classList.remove('hidden');
    }
    if(S.timeLeft<=0){ clearInterval(S.timerInterval); forcedSubmit(); }
  },1000);
}

function forcedSubmit(){
  S.submitted=true;
  document.getElementById('exam-screen').classList.add('hidden');
  showResults(true);
}

// ═══════════ DOTS ═══════════
function renderDots(){
  const bar=document.getElementById('q-dots-bar');
  bar.innerHTML='';
  QUESTIONS.forEach((_,i)=>{
    const d=document.createElement('div');
    d.className='q-dot'+(S.answers[i]!==undefined?' answered':'')+(i===S.current?' current':'')+(S.flagged.has(i)?' flagged':'');
    d.textContent=i+1;
    d.onclick=()=>goTo(i);
    bar.appendChild(d);
  });
}

// ═══════════ RENDER QUESTION ═══════════
function renderQuestion(idx){
  const q=QUESTIONS[idx];
  document.getElementById('q-counter').textContent=`Question ${idx+1} of ${QUESTIONS.length}`;
  document.getElementById('q-badge').innerHTML=`Question ${String(idx+1).padStart(2,'0')}${S.flagged.has(idx)?' &nbsp;⚑':''}`;
  document.getElementById('q-text').innerHTML=q.text;
  document.getElementById('progress-fill').style.width=`${((idx+1)/QUESTIONS.length)*100}%`;
  document.getElementById('prev-btn').disabled=idx===0;
  document.getElementById('next-btn').disabled=idx===QUESTIONS.length-1;
  const fb=document.getElementById('flag-btn');
  fb.textContent=S.flagged.has(idx)?'⚑ Flagged':'⚑ Flag';
  fb.className='flag-btn'+(S.flagged.has(idx)?' flagged':'');
  const letters=Object.keys(q.opts);
  const grid=document.getElementById('options-grid');
  grid.innerHTML='';
  letters.forEach(letter=>{
    const btn=document.createElement('button');
    btn.className='opt-btn'+(S.answers[idx]===letter?' selected':'');
    btn.innerHTML=`<span class="opt-letter">${letter}</span><span class="opt-text">${q.opts[letter]}</span>`;
    btn.onclick=()=>selectAnswer(idx,letter);
    grid.appendChild(btn);
  });
  renderDots();
  renderMath(document.getElementById('q-card'));
  renderMath(grid);
}

function selectAnswer(idx,letter){
  S.answers[idx]=letter;
  document.querySelectorAll('.opt-btn').forEach(btn=>{
    btn.className='opt-btn'+(btn.querySelector('.opt-letter').textContent===letter?' selected':'');
  });
  renderDots();
}

function goTo(idx){ S.current=idx; renderQuestion(idx); }

// ═══════════ SUBMIT ═══════════
function submitPaper(){
  if(S.submitted) return;
  const un=QUESTIONS.filter((_,i)=>S.answers[i]===undefined).length;
  if(un>0 && !confirm(`You have ${un} unanswered question${un>1?'s':''}. Submit the paper?`)) return;
  clearInterval(S.timerInterval);
  S.submitted=true;
  document.getElementById('exam-screen').classList.add('hidden');
  showResults(false);
}

// ═══════════ RESULTS ═══════════
function showResults(forced){
  document.getElementById('results-screen').classList.remove('hidden');
  let correct=0, wrong=0, skipped=0;
  QUESTIONS.forEach((q,i)=>{
    if(S.answers[i]===undefined) skipped++;
    else if(S.answers[i]===q.ans) correct++;
    else wrong++;
  });
  const grade=GRADE_TABLE[correct];
  document.getElementById('results-heading').innerHTML=`${S.name ? S.name+"'s " : 'Your '}<em>Results</em>`;
  document.getElementById('score-raw').textContent=correct;
  document.getElementById('score-grade').textContent=grade.toFixed(1);
  document.getElementById('score-breakdown').innerHTML=`<span style="color:var(--green)">${correct}✓</span> / <span style="color:var(--red)">${wrong}✗</span> / <span style="color:var(--amber)">${skipped}–</span>`;
  const pt=document.getElementById('perf-tag');
  if(grade>=7.5){pt.textContent='Excellent';pt.className='perf-tag perf-excellent';}
  else if(grade>=6.0){pt.textContent='Good';pt.className='perf-tag perf-good';}
  else if(grade>=4.5){pt.textContent='Average';pt.className='perf-tag perf-avg';}
  else{pt.textContent='Below average';pt.className='perf-tag perf-below';}
  // Build email report
  const wrong_qs = QUESTIONS.filter((q,i)=>S.answers[i]!==undefined && S.answers[i]!==q.ans).map(q=>`Q${q.id}`).join(', ')||'None';
  const skipped_qs = QUESTIONS.filter((_,i)=>S.answers[i]===undefined).map((_,i)=>`Q${i+1}`).join(', ')||'None';
  const subject=encodeURIComponent(`TMUA Simulator Result — ${S.name||'Candidate'} — 2016 Paper 1`);
  const body=encodeURIComponent(
`TMUA 2016 Paper 1 — Simulation Result
=======================================
Candidate:    ${S.name||'(not provided)'}
Date:         ${new Date().toLocaleDateString('en-GB',{day:'2-digit',month:'long',year:'numeric'})}
Time:         ${new Date().toLocaleTimeString('en-GB',{hour:'2-digit',minute:'2-digit'})}

SCORE
Raw Score:    ${correct} / 20
TMUA Grade:   ${grade.toFixed(1)}  (scale 1.0–9.0)
Correct:      ${correct}
Incorrect:    ${wrong}
Skipped:      ${skipped}

DETAIL
Questions answered incorrectly: ${wrong_qs}
Questions skipped:               ${skipped_qs}

FULL ANSWER LOG
${QUESTIONS.map((q,i)=>{
  const ua=S.answers[i]||'–';
  const outcome=S.answers[i]===undefined?'SKIPPED':(S.answers[i]===q.ans?'CORRECT':'WRONG');
  return `Q${q.id}: Your answer: ${ua}  Correct: ${q.ans}  [${outcome}]`;
}).join('\n')}

— Sent automatically from the TMUA Simulator (Ned Broderick Tutoring)`
  );
  document.getElementById('email-report-link').href=`mailto:ned.broderick@btinternet.com?subject=${subject}&body=${body}`;
  // Review grid
  const grid=document.getElementById('rq-grid');
  grid.innerHTML='';
  QUESTIONS.forEach((q,i)=>{
    const isCorrect=S.answers[i]===q.ans;
    const isSkipped=S.answers[i]===undefined;
    const b=document.createElement('button');
    b.className='rq-btn '+(isSkipped?'skipped':(isCorrect?'correct':'incorrect'));
    b.innerHTML=`<span class="rq-num">Q${i+1}</span><span class="rq-mark">${isSkipped?'—':(isCorrect?'✓':'✗')}</span>`;
    b.onclick=()=>openReview(i);
    grid.appendChild(b);
  });
}

// ═══════════ REVIEW MODAL ═══════════
function openReview(idx){
  S.reviewQ=idx;
  renderReview(idx);
  document.getElementById('review-modal').classList.remove('hidden');
}

function renderReview(idx){
  const q=QUESTIONS[idx];
  const ua=S.answers[idx];
  document.getElementById('rev-badge').textContent=`Question ${idx+1} of ${QUESTIONS.length}`;
  document.getElementById('rev-prev').disabled=idx===0;
  document.getElementById('rev-next').disabled=idx===QUESTIONS.length-1;
  const letters=Object.keys(q.opts);
  let statusCls='rev-status skipped', statusMsg=`Not answered — correct answer: <strong>${q.ans}</strong>`;
  if(ua!==undefined){
    if(ua===q.ans){statusCls='rev-status correct'; statusMsg=`✓ Correct — you selected <strong>${ua}</strong>`;}
    else{statusCls='rev-status incorrect'; statusMsg=`✗ Incorrect — you selected <strong>${ua}</strong>, correct answer is <strong>${q.ans}</strong>`;}
  }
  let optsHTML=letters.map(l=>{
    const isUser=l===ua, isCorrect=l===q.ans;
    let cls='rev-opt', tag='';
    if(isUser && isCorrect){cls+=' user-correct'; tag='<span class="rev-tag tag-correct">Your answer ✓</span>';}
    else if(isUser && !isCorrect){cls+=' user-wrong'; tag='<span class="rev-tag tag-wrong">Your answer ✗</span>';}
    else if(!isUser && isCorrect){cls+=' correct-hi'; tag='<span class="rev-tag tag-correct">Correct answer</span>';}
    return `<div class="${cls}"><span class="rev-opt-letter">${l}</span><span class="rev-opt-text">${q.opts[l]}${tag}</span></div>`;
  }).join('');
  document.getElementById('rev-body').innerHTML=`
    <div class="rev-q-text">${q.text}</div>
    <div class="${statusCls}">${statusMsg}</div>
    <div class="rev-options">${optsHTML}</div>
    <div class="rev-solution"><div class="rev-sol-label">Worked Solution</div><div class="rev-sol-text">${q.sol}</div></div>`;
  renderMath(document.getElementById('rev-body'));
}

// ═══════════ EVENT LISTENERS ═══════════
document.getElementById('begin-btn').onclick=()=>{
  const n=document.getElementById('candidate-name').value.trim();
  if(!n){document.getElementById('name-error').style.display='block';return;}
  document.getElementById('name-error').style.display='none';
  S.name=n;
  document.getElementById('header-name').textContent='· '+n;
  document.getElementById('start-screen').classList.add('hidden');
  document.getElementById('exam-screen').classList.remove('hidden');
  S.started=true;
  renderQuestion(0);
  startTimer();
};
document.getElementById('candidate-name').addEventListener('keydown',e=>{if(e.key==='Enter') document.getElementById('begin-btn').click();});
document.getElementById('warn-dismiss').onclick=()=>document.getElementById('warn-overlay').classList.add('hidden');
document.getElementById('prev-btn').onclick=()=>goTo(S.current-1);
document.getElementById('next-btn').onclick=()=>goTo(S.current+1);
document.getElementById('submit-btn').onclick=submitPaper;
document.getElementById('flag-btn').onclick=()=>{
  if(S.flagged.has(S.current)) S.flagged.delete(S.current);
  else S.flagged.add(S.current);
  renderQuestion(S.current);
};
document.getElementById('rev-prev').onclick=()=>{S.reviewQ--;renderReview(S.reviewQ);};
document.getElementById('rev-next').onclick=()=>{S.reviewQ++;renderReview(S.reviewQ);};
document.getElementById('close-review').onclick=()=>document.getElementById('review-modal').classList.add('hidden');
document.getElementById('review-backdrop').onclick=()=>document.getElementById('review-modal').classList.add('hidden');

document.addEventListener('keydown',e=>{
  if(!document.getElementById('review-modal').classList.contains('hidden')){
    if(e.key==='ArrowLeft'&&S.reviewQ>0){S.reviewQ--;renderReview(S.reviewQ);}
    if(e.key==='ArrowRight'&&S.reviewQ<QUESTIONS.length-1){S.reviewQ++;renderReview(S.reviewQ);}
    if(e.key==='Escape') document.getElementById('review-modal').classList.add('hidden');
    return;
  }
  if(!S.started||S.submitted) return;
  if(e.key==='ArrowLeft'&&S.current>0) goTo(S.current-1);
  if(e.key==='ArrowRight'&&S.current<QUESTIONS.length-1) goTo(S.current+1);
  const letters=Object.keys(QUESTIONS[S.current].opts);
  const k=e.key.toUpperCase();
  if(letters.includes(k)) selectAnswer(S.current,k);
});
</script>
